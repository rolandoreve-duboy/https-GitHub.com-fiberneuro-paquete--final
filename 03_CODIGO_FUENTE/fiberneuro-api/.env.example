# Backend FiberNeuro API - Variables de Entorno

# Base de Datos
DATABASE_URL=postgresql://user:password@localhost:5432/fiberneuro

# Servidor API
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=False

# Autenticación
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Correo (Opcional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Configuración de CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
